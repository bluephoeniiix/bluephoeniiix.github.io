l: f3 }} />\n);\n\nexport const X0Component = () => (\n  <div style={{\n      whiteSpace: 'nowrap',\n      display: 'inline-block',\n    }}  dangerouslySetInnerHTML={{ __html: x0 }} />\n);\n\nexport const LMaxComponent = () => (\n  <div style={{\n      whiteSpace: 'nowrap',\n      display: 'inline-block',\n    }}  dangerouslySetInnerHTML={{ __html: lmax }} />\n);\n\nexport const ZVecComponent = () => (\n  <div style={{\n      whiteSpace: 'nowrap',\n      display: 'inline-block',\n    }}  dangerouslySetInnerHTML={{ __html: ZVec }} />\n);\n\nexport const F4Component = () => (\n  <div  style={{\n      fontSize: '9px',\n    }}   dangerouslySetInnerHTML={{ __html: f4 }} />\n);\n\nexport const VecCComponent = () => (\n  <div  style={{\n      whiteSpace: 'nowrap',\n      display: 'inline-block',\n    }}   dangerouslySetInnerHTML={{ __html: VecC }} />\n);\n\nexport const F5Component = () => (\n  <div  style={{\n      whiteSpace: 'nowrap',\n      display: 'inline-block',\n    }}   dangerouslySetInnerHTML={{ __html: f5 }} />\n);\n\nexport const WeComponent = () => (\n  <div  style={{\n      whiteSpace: 'nowrap',\n      display: 'inline-block',\n    }}   dangerouslySetInnerHTML={{ __html: we}} />  \n);\n\nexport const WpComponent = () => (\n  <div  style={{\n      whiteSpace: 'nowrap',\n      display: 'inline-block',\n    }}   dangerouslySetInnerHTML={{ __html: wp}} />  \n);\n\nexport const WeBelongToComponent = () => (\n  <div  style={{\n      whiteSpace: 'nowrap',\n      display: 'inline-block',\n    }}   dangerouslySetInnerHTML={{ __html: webelongto }} />  \n);\n\nexport const DeComponent = () => (\n  <div  style={{\n      whiteSpace: 'nowrap',\n      display: 'inline-block',\n    }}   dangerouslySetInnerHTML={{ __html: de }} />   \n);\n\nexport const SmallTComponent = () => (\n   <div  style={{\n      whiteSpace: 'nowrap',\n      display: 'inline-block',\n    }}   dangerouslySetInnerHTML={{ __html: small_t }} />  \n);\n\nexport const WeQueryTComponent = () => (\n   <div  style={{\n      whiteSpace: 'nowrap',\n      display: 'inline-block',\n    }}   dangerouslySetInnerHTML={{ __html: we_q_t }} /> \n);\n\nexport const SmallIComponent = () => (\n     <div  style={{\n      whiteSpace: 'nowrap',\n      display: 'inline-block',\n    }}   dangerouslySetInnerHTML={{ __html: SmallI }} /> \n);\n\nexport const PeComponent = () => (\n     <div  dangerouslySetInnerHTML={{ __html: pe }} />  \n);\n\nexport const VecEComponent = () => (\n     <div  style={{\n      whiteSpace: 'nowrap',\n      display: 'inline-block',\n    }}   dangerouslySetInnerHTML={{ __html: e_vec }} /> \n);\n\nexport const VecEEq = () => (\n     <div   dangerouslySetInnerHTML={{ __html: e_eq }} /> \n);\n\n继续按照上一篇的步骤：\n\n## architectural components\n\n接下来是 word embedding 和 positional encoding，其中 pe 的概念尤其的难懂，这篇文章详细的介绍一下 pe\n\n### token embeddings\n\n给定矩阵 <WeComponent />，<WeBelongToComponent />，其中 <DeComponent /> 为 embedding 后的一个维度，经过 token embedding 后的 token list 会被彻底打散成矩阵，另外一个维度是 <NUnderscoreVComponent />，为 token list 的长度\n\n查询在这个矩阵当中标号为 <SmallTComponent /> 的 embedding 后的 token，结果用 <WeQueryTComponent />（<SmallTComponent /> 为 token id），embedding是如何将 token list 打散成这样的矩阵，这里不深究\n\n### pe \n\n给定 token list 的最大长度 <LMaxComponent />， 且 <TSmallerThanLMaxComponent />\n\n定义下角标 <SmallIComponent />，0 < <SmallIComponent /> <= 0.5 <DeComponent />，目标输出 <WpComponent />：\n\n<PeComponent />\n\n最后将 pe 和 embedding 相加得到 <VecEComponent />：\n\n<VecEEq />\n\n下面介绍以下 pe 如此设计的原因：\n\n如果想要表示一个 token 序列的位置信息，最简单的方法：\"I Love PIG DUCK DOG CAT HUMAN ALIEN\" -> [0, 1, 2, 3, 4, 5, 7, 8]，但是这样的表示方法在机器学习里是禁止的\n\n如果按照 transformer 的处理逻辑（<WeComponent /> 必须要用某种方式和 <WpComponent /> 结合生成向量 <VecEComponent /> ），神经网络在前置阶段必须将输入单词（token）转换为**一个统一的向量**作为输入，这个输入仅仅是一串数字并且这串数字要有能力**同时表示**：\n\n1. 位置，这串数字到底是这句话的第几个单词（token）\n2. 单词自身的信息不能丢失\n\n### 简单位置编码\n\n\"I Love PIG DUCK DOG CAT HUMAN ALIEN\" -> [0, 1, 2, 3, 4, 5, 7, 8] 这种方式满足 1，但不满足 2，原因是当序列很长的话末尾的数字会非常大，任何的大数都很难用手段把它消除，所以会导致单词自身的信息被抹平，从而导致梯度爆炸\n\n根据这个原因，我们将 [0, 1, 2, 3, 4, 5, 7, 8] 变为 [0, 1/8, 2/8, 3/8, 4/8, .. 1]，这样将数字压缩的很小，绝对不会导致单词自身信息的丢失，满足了条件 2，也似乎满足条件 1，因为这个 token list 的长度乘以这个值就可以获得位置\n\n但是这个方案依旧不可以，原因是 “4/8” 这个数字不可能有机会在计算过程中乘以 token list 的长度。因为我们首先假定了神经网络只能处理一个向量化的实体，这个实体不可能以 append 的形式附加 token list 一个多维数组的列来代表 token list 的长度和 [0, 1/8, 2/8, 3/8, 4/8, .. 1] 这种形式，这违背了神经网络的设计初衷\n\n如果满足将 [0, 1/8, 2/8, 3/8, 4/8, .. 1] 这种位置编码与 token list 用某种方式计算（合二为一），则会不满足条件 1，因为形如 “4/8” 这种数字过于的模糊，它既可以表示长度为 10 的 token list 中的第 5 个，也可以表示长度为 8 的 token list 中的第 4 个\n\n假设句 A 长度为 1000 token，最中间单词（第 500 个）是 what，句 B 长度为 10，最中间单词依旧是 \"what\"（第 5 个），这两个单词的位置编码都是 0.5，但是这两个 \"what\" 所代表的信息在 nlp 中真的一致么？\n\n如果 \"what\" 在句 A 中做提问，在 B 中做从句，这种方式计算出来的 <VecEComponent /> 值完全一致，因为 \"what\" 的 embedding 值由自身决定，两个 \"what\" 的 embedding 值相同，当 pe 值依旧一致的时，<VecEComponent /> 向量一定一致；神经网络会认为两个 \"what\" 完全一致，导致不能正确理解 \"what\" 的用法\n\n### 二进制位置编码\n\n经过之前的论证，位置编码已经由原本的简单问题变得复杂化了，如果采用二进制位置编码会是 pe 的解决方案么？答案是否定的\n\n比如第 35 号 token 的位置编码为：100011 -> [1, 0, 0, 0, 1, 1]，经过 y = 2x - 1 正则化后得到： [1, -1, -1, -1, 1, 1]\n\n使用二进制编码既满足了条件 2，又满足了条件 1，但是依旧不可行，因为第 36 号 token 和第 35、34、33 号 token 不形成函数关系\n\n所以接下来的目标变为用函数模拟二进制序列\n\n### 三角函数位置编码\n\ntodo\n\n### 纯sin函数模拟\n\ntodo\n\n### 放缩周期的纯 sin 函数模拟\n\ntodo\n\n### sin 和 cos 交替表示 pe 的本质原因\n\ntodo\n\n\n\n\n\n\n\n\n\n","type":"Mdx","contentDigest":"d7c4f1bc850772eb6ec185eef7cf8e0a","owner":"gatsby-plugin-mdx","counter":314},"frontmatter":{"description":"Ai / Tr 2","title":"Ai / Tr 2"},"exports":{},"rawBody":"import HomepageTemplate from './Template.js';\nexport default HomepageTemplate;\n\n# <span style=\"color: #6021BE; font-size: 30px; font-weight: bold;\">Transformer Basic Part Two</span>\n\nexport const SmallI = `\n<math xmlns=\"http://www.w3.org/1998/Math/MathML\">\n  <mi>i</mi>\n</math>\n`;\n\nexport const BigV = `\n<math xmlns=\"http://www.w3.org/1998/Math/MathML\">\n  <mi>V</mi>\n</math>\n`;\n\nexport const XVec = `\n<math xmlns=\"http://www.w3.org/1998/Math/MathML\">\n  <mrow class=\"MJX-TeXAtom-ORD\">\n    <mover>\n      <mi>x</mi>\n      <mo stretchy=\"false\">&#x2192;<!-- → --></mo>\n    </mover>\n  </mrow>\n</math>\n`;\n\nexport const VStar = `\n<math xmlns=\"http://www.w3.org/1998/Math/MathML\">\n  <msup>\n    <mi>V</mi>\n    <mo>&#x2217;<!-- ∗ --></mo>\n  </msup>\n</math>\n`;\n\nexport const NUnderscoreV = `\n<math xmlns=\"http://www.w3.org/1998/Math/MathML\">\n  <msub>\n    <mi>N</mi>\n    <mi>V</mi>\n  </msub>\n</math>\n`;\n\nexport const f1 = `\n<math xmlns=\"http://www.w3.org/1998/Math/MathML\">\n  <mrow class=\"MJX-TeXAtom-ORD\">\n    <mover>\n      <mi>x</mi>\n      <mo stretchy=\"false\">&#x2192;<!-- → --></mo>\n    </mover>\n  </mrow>\n  <mo>=</mo>\n  <mi>x</mi>\n  <mo stretchy=\"false\">[</mo>\n  <mn>1</mn>\n  <mo stretchy=\"false\">]</mo>\n  <mo>,</mo>\n  <mi>x</mi>\n  <mo stretchy=\"false\">[</mo>\n  <mn>2</mn>\n  <mo stretchy=\"false\">]</mo>\n  <mo>,</mo>\n  <mi>x</mi>\n  <mo stretchy=\"false\">[</mo>\n  <mn>3</mn>\n  <mo stretchy=\"false\">]</mo>\n  <mo>.</mo>\n  <mo>.</mo>\n  <mo>.</mo>\n  <mi>x</mi>\n  <mo stretchy=\"false\">[</mo>\n  <msub>\n    <mi>l</mi>\n    <mrow class=\"MJX-TeXAtom-ORD\">\n      <mi>m</mi>\n      <mi>a</mi>\n      <mi>x</mi>\n    </mrow>\n  </msub>\n  <mo stretchy=\"false\">]</mo>\n  <mo>&#x2208;<!-- ∈ --></mo>\n  <msup>\n    <mi>V</mi>\n    <mo>&#x2217;<!-- ∗ --></mo>\n  </msup>\n</math>\n`;\n\nexport const x0 = `\n<math xmlns=\"http://www.w3.org/1998/Math/MathML\">\n  <mi>x</mi>\n  <mo stretchy=\"false\">[</mo>\n  <mn>0</mn>\n  <mo stretchy=\"false\">]</mo>\n</math>\n`;\n\nexport const lmax = `\n<math xmlns=\"http://www.w3.org/1998/Math/MathML\">\n  <msub>\n    <mi>l</mi>\n    <mrow class=\"MJX-TeXAtom-ORD\">\n      <mi>m</mi>\n      <mi>a</mi>\n      <mi>x</mi>\n    </mrow>\n  </msub>\n</math>`;\n\nexport const f2 = `\n<math xmlns=\"http://www.w3.org/1998/Math/MathML\">\n  <mrow class=\"MJX-TeXAtom-ORD\">\n    <mover>\n      <mi>x</mi>\n      <mo stretchy=\"false\">&#x2192;<!-- → --></mo>\n    </mover>\n  </mrow>\n  <mo stretchy=\"false\">[</mo>\n  <mn>1</mn>\n  <mo>:</m